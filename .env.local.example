# Copy to `.env.local` and fill in values. `.env.local` is gitignored (`*.local`).

# --- Optional API ---
# Same-origin `/api/*` when unset. Set when the SPA talks to another host.
# NEXT_PUBLIC_API_BASE_URL=https://your-api.example.com

# --- App login (Pages Functions session cookie) ---
# When true, `/app` is gated until login succeeds (see `src/lib/auth-store.ts`).
# NEXT_PUBLIC_REQUIRE_AUTH=true

# --- Firebase client (production) ---
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase emulators (local) ---
# After `npm run emulators:start`, point the web app at emulators:
# NEXT_PUBLIC_FIRESTORE_EMULATOR_HOST=127.0.0.1:8455
# NEXT_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
# NEXT_PUBLIC_FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199

# --- Realtime station bridge (optional) ---
# When enabled, the app opens a WebSocket and applies remote `cmd_broadcast` to the player.
# Use the same tenant/station slugs as D1 (`migrations/0004_multi_tenant.sql` defaults).
# NEXT_PUBLIC_REALTIME_ENABLED=true
# NEXT_PUBLIC_REALTIME_TENANT_ID=tnt-default
# NEXT_PUBLIC_REALTIME_STATION_ID=st-default
# NEXT_PUBLIC_REALTIME_MODE=viewer
# If `REALTIME_WS_URL` is not returned from POST /api/realtime/token, set the Worker origin (no trailing /ws):
# NEXT_PUBLIC_REALTIME_WS_URL=ws://127.0.0.1:8788
# Program VU frames to the worker (operator/meter). Set false to send cmds only:
# NEXT_PUBLIC_REALTIME_PUSH_VU=false
